      "title": "Active Jobs",
      "type": "stat",
      "targets": [{"expr": "jobs_active", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 12},
      "id": 12,
      "options": {"colorMode": "value"},
