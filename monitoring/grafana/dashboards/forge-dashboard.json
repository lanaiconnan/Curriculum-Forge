      "type": "stat",
      "targets": [{"expr": "sum(increase(jobs_completed_total{state=\"FAILED\"}[1h]))", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 12},
