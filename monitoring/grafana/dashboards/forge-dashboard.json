      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16},
      "id": 17,
      "title": "Job Duration Distribution",
      "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.50, sum(rate(job_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"}, {"expr": "histogram_quantile(0.95, sum(rate(job_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"}]
    },
    {
      "collapsed": false,
